# ============================================================
# 3Netra-AI — .gitignore
# ============================================================

# Environment variables — NEVER commit these
.env
.env.local
.env.*.local
.env.development
.env.production

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
htmlcov/

# Node.js
node_modules/
.npm/
npm-debug.log*

# Next.js
.next/
out/
.vercel/

# SQLite databases (auto-created, not committed)
memory/*.db
memory/*.db-shm
memory/*.db-wal

# Playwright state
playwright-report/
test-results/
.playwright/

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
logs/

# Docker
.docker/

# Temporary files
*.tmp
*.temp

# WeasyPrint cache
.weasyprint/

# Sentence Transformers model cache
.cache/
models/
