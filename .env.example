# ============================================================
# 3Netra-AI — Environment Variables
#
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in every value marked [REQUIRED]
# 3. Never commit .env.local to GitHub (it's in .gitignore)
# 4. Variables marked [OPTIONAL] can be left blank for now
#
# WHERE TO GET EACH KEY — see SETUP.md for step-by-step
# ============================================================

# ────────────────────────────────────────────────────────────
# ANTHROPIC — AI model API
# Get from: console.anthropic.com → API Keys
# Free credit: $5 (covers ~29 full sessions at $0.17 each)
# ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...                     # [REQUIRED]

# ────────────────────────────────────────────────────────────
# LLM MODEL ROUTING via litellm
# Default: Claude Haiku (fast/cheap) + Sonnet (quality)
# To switch ALL models to GPT-4: change both to gpt-4o / gpt-4o-mini
# To switch to free Groq: groq/llama-3.1-70b-versatile
# ────────────────────────────────────────────────────────────
LLM_FAST_MODEL=claude-haiku-4-5                  # [REQUIRED] advisors, quiz, annotations
LLM_STRONG_MODEL=claude-sonnet-4-6               # [REQUIRED] chairman, code gen, diagrams
LLM_MAX_CONCURRENT=10                            # max parallel AI calls (default: 10)
LLM_FAST_TIMEOUT=30                              # haiku timeout in seconds
LLM_STRONG_TIMEOUT=60                            # sonnet timeout in seconds

# ────────────────────────────────────────────────────────────
# SUPABASE — Database + Auth + Storage + Realtime
# Get from: supabase.com → Project Settings → API
# Use the SERVICE ROLE key (not the anon key) for backend
# ────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co   # [REQUIRED]
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6Ikp... # [REQUIRED] service_role key
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cC... # [REQUIRED] anon key (for frontend)

# ────────────────────────────────────────────────────────────
# VALKEY — Cache (runs in Docker)
# No setup needed — docker compose up valkey -d starts it
# ────────────────────────────────────────────────────────────
VALKEY_URL=redis://localhost:6379                # [REQUIRED] don't change for local dev

# ────────────────────────────────────────────────────────────
# MCP SERVER — Your custom project memory server
# Starts on port 8001. Keep as-is for local dev.
# ────────────────────────────────────────────────────────────
MCP_SERVER_URL=http://localhost:8001             # [REQUIRED]
MCP_SERVER_PORT=8001                             # [REQUIRED]

# ────────────────────────────────────────────────────────────
# GITHUB — Research agent + career output
# Get from: github.com → Settings → Developer Settings → Personal Access Tokens
# Scopes needed: repo (read), public_repo
# ────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...                             # [REQUIRED for Stage 2+]

# ────────────────────────────────────────────────────────────
# BACKEND
# ────────────────────────────────────────────────────────────
PORT=8000                                        # FastAPI port
FRONTEND_URL=http://localhost:3000               # CORS allowed origin
                                                 # Change to Vercel URL in production

# ────────────────────────────────────────────────────────────
# FRONTEND (Next.js — prefix with NEXT_PUBLIC_ to expose to browser)
# ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000        # [REQUIRED] backend URL
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co # [REQUIRED] same as SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...             # [REQUIRED] same as SUPABASE_ANON_KEY

# ────────────────────────────────────────────────────────────
# SENTRY — Error tracking (Stage 11 — leave blank until QA stage)
# Get from: sentry.io → New Project → Python/FastAPI
# ────────────────────────────────────────────────────────────
SENTRY_DSN=                                      # [OPTIONAL — add in Stage 11]

# ────────────────────────────────────────────────────────────
# ENVIRONMENT
# ────────────────────────────────────────────────────────────
ENVIRONMENT=development                          # development | production
DEBUG=true                                       # set false in production
